{
  "name": "encoder-ai",
  "description": "MEOK AI Labs \u2014 Encoding and decoding \u2014 Base64, URL, HTML, hex, binary.",
  "version": "1.0.0",
  "protocol_version": "2025-11-25",
  "publisher": {
    "name": "MEOK AI Labs",
    "url": "https://meok.ai",
    "email": "nicholas@meok.ai"
  },
  "repository": "https://github.com/CSOAI-ORG/encoder-ai-mcp",
